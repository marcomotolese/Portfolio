APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Vercel (production) — copia queste variabili nel dashboard del progetto Vercel
# (Settings → Environment Variables). Non committare segreti nel repo.
#
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://il-tuo-progetto.vercel.app
# APP_KEY=base64:...   # php artisan key:generate --show
#
# LOG_CHANNEL=stderr
# LOG_LEVEL=error
#
# Session serverless: cookie (non "file" su filesystem read-only tra invocazioni)
# SESSION_DRIVER=cookie
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
#
# Cache in RAM per istanza (ok per portfolio senza DB)
# CACHE_STORE=array
# QUEUE_CONNECTION=sync
#
# Scritture Laravel solo in /tmp (filesystem serverless)
# VIEW_COMPILED_PATH=/tmp/laravel/views
# APP_CONFIG_CACHE=/tmp/laravel/config.php
# APP_EVENTS_CACHE=/tmp/laravel/events.php
# APP_PACKAGES_CACHE=/tmp/laravel/packages.php
# APP_ROUTES_CACHE=/tmp/laravel/routes-v7.php
# APP_SERVICES_CACHE=/tmp/laravel/services.php
#
# Mail form contatto (stessi valori di produzione SMTP)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=
# MAIL_FROM_NAME="Marco Motolese"
#
# DB opzionale (es. Neon, PlanetScale): solo se aggiungi funzioni che usano il DB
# DB_CONNECTION=mysql
# DB_HOST=
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
# -----------------------------------------------------------------------------
