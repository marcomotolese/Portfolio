{
    "version": 2,
    "regions": ["fra1"],
    "buildCommand": "npm ci --include=dev && npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/build/$1" },
        { "src": "/", "dest": "/api/index.php" },
        { "src": "/index.php", "dest": "/api/index.php" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
